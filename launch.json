{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "site",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const http=require('http'),fs=require('fs'),path=require('path'),dir=process.cwd(),mime={'html':'text/html','css':'text/css','js':'application/javascript','png':'image/png','jpg':'image/jpeg','jpeg':'image/jpeg','svg':'image/svg+xml','json':'application/json','ico':'image/x-icon'};http.createServer((q,r)=>{let f=q.url==='/'?'/index.html':decodeURIComponent(q.url);let p=path.join(dir,f);fs.readFile(p,(e,d)=>{if(e){r.writeHead(404);r.end('Not found');return}let ext=path.extname(p).slice(1);r.writeHead(200,{'Content-Type':mime[ext]||'application/octet-stream'});r.end(d)})}).listen(3000,()=>console.log('Server running on port 3000'))"],
      "port": 3000
    }
  ]
}
